PORT=3001
ADMIN_USER=admin
ADMIN_PASS=admin

# When using a public tunnel, set this to your tunnel origin (no trailing slash) so /api/videos returns
# playable URLs on phones. Example: https://abc-123.tunnelmole.net
# PUBLIC_BASE_URL=

# Optional: store uploads on S3 instead of local disk (free tier: https://aws.amazon.com/free/)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket
# Public base for object URLs (no trailing slash), e.g. https://your-bucket.s3.us-east-1.amazonaws.com
# Or CloudFront: https://dxxxx.cloudfront.net
# S3_PUBLIC_BASE_URL=
